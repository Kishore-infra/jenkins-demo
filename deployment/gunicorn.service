[Unit]
Description=Gunicorn service for Flask app
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/jenkins.demo
Environment="PATH=/home/ubuntu/jenkins.demo/venv/bin"
ExecStart=/home/ubuntu/jenkins.demo/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 app:app

[Install]
WantedBy=multi-user.target
